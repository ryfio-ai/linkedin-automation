{
  "name": "LinkedIn AI Content Automation Platform",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 20 8 * * *" },
            { "field": "cronExpression", "expression": "0 50 18 * * *" }
          ]
        }
      },
      "id": "trigger_schedule",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [ 100, 300 ]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Calendar", "mode": "name" }
      },
      "id": "read_rows",
      "name": "Google Sheets (Read Rows)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 300, 300 ]
    },
    {
      "parameters": {
        "action": "format",
        "value": "={{ $json.Date }}",
        "toFormat": "YYYY-MM-DD"
      },
      "id": "date_time",
      "name": "Date & Time (Parse)",
      "type": "n8n-nodes-base.dateTime",
      "typeVersion": 2,
      "position": [ 500, 300 ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.Status }}", "value2": "Not Posted" },
            { "value1": "={{ $json.formattedDate }}", "value2": "={{ $now.format('YYYY-MM-DD') }}" },
            { "value1": "={{ $json.Time.split(':')[0] }}", "value2": "={{ $now.format('HH') }}" }
          ]
        }
      },
      "id": "if_today",
      "name": "IF (Not Posted, Today, & Matching Hour)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [ 700, 300 ]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Calendar", "mode": "name" },
        "rowNumber": "={{ $json.row_number }}",
        "columns": { "mappingMode": "defineBelow", "value": { "Status": "Posting" } }
      },
      "id": "status_posting",
      "name": "Update Status (Posting)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 900, 300 ]
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n  ...item,\n  json: {\n    ...item.json,\n    _execution_context: {\n      row_number: item.json.row_number,\n      post_date: item.json.Date,\n      post_time: item.json.Time\n    }\n  }\n}));"
      },
      "id": "preserve_context",
      "name": "Code (Preserve Row Context)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [ 1100, 300 ]
    },
    {
      "parameters": {
        "prompt": "=You are writing for my personal LinkedIn profile.\nPost:\n{{ $json.Post }}",
        "model": "={{ $env.GEMINI_MODEL }}"
      },
      "id": "gemini",
      "name": "Gemini (Rewrite)",
      "type": "n8n-nodes-base.googleGemini",
      "typeVersion": 1,
      "position": [ 1300, 300 ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": { "boolean": [ { "value1": "={{ $json.error ? false : true }}", "value2": true } ] }
      },
      "id": "if_gemini_success",
      "name": "IF (Gemini Success)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [ 1500, 300 ]
    },
    {
      "parameters": {
        "conditions": { "string": [ { "value1": "={{ $('IF (Not Posted, Today, & Matching Hour)').item.json.Image }}", "operation": "isNotEmpty" } ] }
      },
      "id": "check_image",
      "name": "IF Image Exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [ 1700, 200 ]
    },
    {
      "parameters": {
        "method": "HEAD",
        "url": "={{ $('IF (Not Posted, Today, & Matching Hour)').item.json.Image }}"
      },
      "id": "validate_image",
      "name": "Validate Image URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [ 1900, 100 ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": { "number": [ { "value1": "={{ $response.statusCode }}", "value2": 200 } ] }
      },
      "id": "if_image_valid",
      "name": "IF Image Valid (200)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [ 2100, 100 ]
    },
    {
      "parameters": {
        "text": "={{ $json.text }}",
        "profile": "={{ $env.BUFFER_PROFILE_ID }}",
        "now": true,
        "media": [ "={{ $('IF (Not Posted, Today, & Matching Hour)').item.json.Image }}" ]
      },
      "id": "buffer_image",
      "name": "Buffer (Image)",
      "type": "n8n-nodes-base.buffer",
      "typeVersion": 1,
      "position": [ 2300, 50 ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "text": "={{ $('Gemini (Rewrite)').item.json.text }}",
        "profile": "={{ $env.BUFFER_PROFILE_ID }}",
        "now": true
      },
      "id": "buffer_text",
      "name": "Buffer (Text)",
      "type": "n8n-nodes-base.buffer",
      "typeVersion": 1,
      "position": [ 2300, 350 ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": { "boolean": [ { "value1": "={{ $json.error ? false : true }}", "value2": true } ] }
      },
      "id": "if_buffer_success",
      "name": "IF Buffer Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [ 2500, 200 ]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Calendar", "mode": "name" },
        "rowNumber": "={{ $('Code (Preserve Row Context)').item.json._execution_context.row_number }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Status": "Posted",
            "Posted At": "={{ $now }}",
            "Buffer ID": "={{ $json.id }}",
            "LinkedIn URL": "={{ $json.share_url }}",
            "AI Version": "={{ $env.GEMINI_MODEL }}"
          }
        }
      },
      "id": "update_sheet_final",
      "name": "Google Sheets Update (Final)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 2700, 200 ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Logs", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Date": "={{ $now }}",
            "Workflow": "LinkedIn AI Automation",
            "Status": "Success",
            "LinkedIn URL": "={{ $json.share_url }}"
          }
        }
      },
      "id": "append_logs",
      "name": "Google Sheets (Append Log)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 2900, 200 ]
    },
    {
      "parameters": {},
      "id": "error_trigger",
      "name": "Error Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [ 100, 600 ]
    },
    {
      "parameters": {
        "jsCode": "const errorMsg = items[0].json.error?.message || 'Unknown error';\nconst rowNum = items[0].json._execution_context?.row_number || items[0].json.row_number || 2;\nreturn [{\n  json: {\n    row_number: rowNum,\n    error_message: errorMsg\n  }\n}];"
      },
      "id": "extract_error_context",
      "name": "Code (Extract Error Context)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [ 300, 600 ]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Calendar", "mode": "name" },
        "rowNumber": "={{ $json.row_number }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": { "Status": "Failed", "Error": "={{ $json.error_message }}" }
        }
      },
      "id": "update_error_calendar",
      "name": "Google Sheets (Log Error to Calendar)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 500, 600 ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "value": "={{ $env.GOOGLE_SHEET_ID }}", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Logs", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Date": "={{ $now }}",
            "Workflow": "LinkedIn AI Automation",
            "Status": "Failed",
            "Error": "={{ $json.error_message }}"
          }
        }
      },
      "id": "append_error_logs",
      "name": "Google Sheets (Append Error Log)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [ 700, 600 ]
    }
  ],
  "connections": {
    "Schedule Trigger": { "main": [ [ { "node": "Google Sheets (Read Rows)", "type": "main", "index": 0 } ] ] },
    "Google Sheets (Read Rows)": { "main": [ [ { "node": "Date & Time (Parse)", "type": "main", "index": 0 } ] ] },
    "Date & Time (Parse)": { "main": [ [ { "node": "IF (Not Posted, Today, & Matching Hour)", "type": "main", "index": 0 } ] ] },
    "IF (Not Posted, Today, & Matching Hour)": { "main": [ [ { "node": "Update Status (Posting)", "type": "main", "index": 0 } ] ] },
    "Update Status (Posting)": { "main": [ [ { "node": "Code (Preserve Row Context)", "type": "main", "index": 0 } ] ] },
    "Code (Preserve Row Context)": { "main": [ [ { "node": "Gemini (Rewrite)", "type": "main", "index": 0 } ] ] },
    "Gemini (Rewrite)": { "main": [ [ { "node": "IF (Gemini Success)", "type": "main", "index": 0 } ] ] },
    "IF (Gemini Success)": { "main": [ [ { "node": "IF Image Exists", "type": "main", "index": 0 } ], [ { "node": "Code (Extract Error Context)", "type": "main", "index": 0 } ] ] },
    "IF Image Exists": { "main": [ [ { "node": "Validate Image URL", "type": "main", "index": 0 } ], [ { "node": "Buffer (Text)", "type": "main", "index": 0 } ] ] },
    "Validate Image URL": { "main": [ [ { "node": "IF Image Valid (200)", "type": "main", "index": 0 } ] ] },
    "IF Image Valid (200)": { "main": [ [ { "node": "Buffer (Image)", "type": "main", "index": 0 } ], [ { "node": "Buffer (Text)", "type": "main", "index": 0 } ] ] },
    "Buffer (Image)": { "main": [ [ { "node": "IF Buffer Success", "type": "main", "index": 0 } ] ] },
    "Buffer (Text)": { "main": [ [ { "node": "IF Buffer Success", "type": "main", "index": 0 } ] ] },
    "IF Buffer Success": { "main": [ [ { "node": "Google Sheets Update (Final)", "type": "main", "index": 0 } ], [ { "node": "Code (Extract Error Context)", "type": "main", "index": 0 } ] ] },
    "Google Sheets Update (Final)": { "main": [ [ { "node": "Google Sheets (Append Log)", "type": "main", "index": 0 } ] ] },
    "Error Trigger": { "main": [ [ { "node": "Code (Extract Error Context)", "type": "main", "index": 0 } ] ] },
    "Code (Extract Error Context)": { "main": [ [ { "node": "Google Sheets (Log Error to Calendar)", "type": "main", "index": 0 } ] ] },
    "Google Sheets (Log Error to Calendar)": { "main": [ [ { "node": "Google Sheets (Append Error Log)", "type": "main", "index": 0 } ] ] }
  }
}
